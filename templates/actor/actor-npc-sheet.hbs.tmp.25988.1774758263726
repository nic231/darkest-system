<form class="flexcol darkest-sheet actor-sheet npc-sheet" autocomplete="off">

  {{!-- Sheet Header --}}
  <header class="sheet-header flexrow">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />

    <div class="header-fields">
      <h1 class="charname">
        <input name="name" type="text" value="{{actor.name}}" placeholder="NPC Name" />
      </h1>

      {{!-- Rating Display --}}
      <div class="rating-container">
        <label>{{localize "DARKEST.Rating"}}</label>
        <div class="rating-dots">
          {{#each ratingDots}}
          <span class="rating-dot {{class}}" data-value="{{value}}" data-field="system.rating"
            title="{{localize 'DARKEST.Rating'}} {{value}}"></span>
          {{/each}}
        </div>
        <span class="rating-value">{{system.rating}}</span>
      </div>
    </div>
  </header>

  {{!-- Sheet Navigation --}}
  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="main">Main</a>
    <a class="item" data-tab="description">{{localize "DARKEST.Actor.Description"}}</a>
  </nav>

  {{!-- Sheet Body --}}
  <section class="sheet-body">

    {{!-- Main Tab --}}
    <div class="tab main" data-group="primary" data-tab="main">

      {{!-- Roll Buttons --}}
      <div class="roll-buttons flexrow">
        <button type="button" class="roll-action">
          <i class="fas fa-dice-d6"></i> {{localize "DARKEST.Roll.Action"}}
        </button>
        <button type="button" class="roll-damage">
          <i class="fas fa-heart-broken"></i> {{localize "DARKEST.Roll.Damage"}}
        </button>
      </div>

      {{!-- Armor --}}
      <section class="armor-section">
        <h3>{{localize "DARKEST.Armor.Name"}}</h3>
        <div class="armor-grid">
          <div class="armor-row">
            <label>{{localize "DARKEST.Armor.Physical"}}</label>
            <input type="number" name="system.armor.physical" value="{{system.armor.physical}}" data-dtype="Number"
              min="0" max="3" />
          </div>
        </div>
      </section>

      {{!-- Abilities --}}
      <section class="abilities-section">
        <div class="section-header">
          <h3>{{localize "DARKEST.Ability.Plural"}}</h3>
          <button type="button" class="item-create" data-type="ability" title="{{localize 'DARKEST.Ability.New'}}">
            <i class="fas fa-plus"></i>
          </button>
        </div>

        <ol class="item-list abilities-list">
          {{#each abilities}}
          <li class="item ability" data-item-id="{{_id}}">
            <img src="{{img}}" class="item-img" />
            <div class="ability-info">
              <span class="ability-name">{{name}}</span>
            </div>
            <div class="item-controls">
              <a class="item-edit" title="Edit"><i class="fas fa-edit"></i></a>
              <a class="item-delete" title="Delete"><i class="fas fa-trash"></i></a>
            </div>
          </li>
          {{/each}}
        </ol>

        {{#unless abilities.length}}
        <p class="empty-list">No special abilities.</p>
        {{/unless}}
      </section>

      {{!-- Tactics --}}
      <section class="tactics-section">
        <h3>{{localize "DARKEST.Actor.Tactics"}}</h3>
        <textarea name="system.tactics" placeholder="Combat tactics and behavior...">{{system.tactics}}</textarea>
      </section>

    </div>

    {{!-- Description Tab --}}
    <div class="tab description" data-group="primary" data-tab="description">
      <section class="description-section">
        <h3>{{localize "DARKEST.Actor.Description"}}</h3>
        <div class="editor-container">
          {{editor enrichedDescription target="system.description" button=true editable=true}}
        </div>
      </section>
    </div>

  </section>

</form>
