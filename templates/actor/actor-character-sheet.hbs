<form class="flexcol darkest-sheet actor-sheet character-sheet" autocomplete="off">

  {{!-- Sheet Header --}}
  <header class="sheet-header flexrow">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />

    <div class="header-fields">
      <h1 class="charname">
        <input name="name" type="text" value="{{actor.name}}" placeholder="Character Name" />
      </h1>

      {{!-- Rating Display --}}
      <div class="rating-container">
        <label>{{localize "DARKEST.Rating"}}</label>
        <div class="rating-dots">
          {{#each ratingDots}}
          <span class="rating-dot {{class}}" data-value="{{value}}" data-field="system.rating"
            title="{{localize 'DARKEST.Rating'}} {{value}}"></span>
          {{/each}}
        </div>
        <span class="rating-value">{{system.rating}}</span>
      </div>

      {{!-- Banes from Wounds --}}
      {{#if totalBanes}}
      <div class="banes-indicator">
        <i class="fas fa-minus-circle"></i>
        <span>{{totalBanes}} {{localize "DARKEST.Banes"}} ({{localize "DARKEST.Wound.Plural"}})</span>
      </div>
      {{/if}}

      {{#if system.unconscious}}
      <div class="status-indicator unconscious">
        <i class="fas fa-dizzy"></i>
        <span>{{localize "DARKEST.Status.Unconscious"}}</span>
      </div>
      {{/if}}

      {{#if system.catatonic}}
      <div class="status-indicator catatonic">
        <i class="fas fa-brain"></i>
        <span>{{localize "DARKEST.Status.Catatonic"}}</span>
      </div>
      {{/if}}
    </div>
  </header>

  {{!-- Sheet Navigation --}}
  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="main">Main</a>
    <a class="item" data-tab="abilities">{{localize "DARKEST.Ability.Plural"}}</a>
    <a class="item" data-tab="equipment">{{localize "DARKEST.Equipment.Plural"}}</a>
    <a class="item" data-tab="biography">{{localize "DARKEST.Actor.Biography"}}</a>
  </nav>

  {{!-- Sheet Body --}}
  <section class="sheet-body">

    {{!-- Main Tab --}}
    <div class="tab main" data-group="primary" data-tab="main">

      {{!-- Roll Buttons --}}
      <div class="roll-buttons flexrow">
        <button type="button" class="roll-action">
          <i class="fas fa-dice-d6"></i> {{localize "DARKEST.Roll.Action"}}
        </button>
      </div>
      <div class="roll-buttons damage-buttons flexrow">
        <button type="button" class="roll-deal-damage">
          <i class="fas fa-fist-raised"></i> {{localize "DARKEST.Roll.DealDamage"}}
        </button>
        <button type="button" class="roll-take-damage">
          <i class="fas fa-heart-broken"></i> {{localize "DARKEST.Roll.TakeDamage"}}
        </button>
      </div>

      {{!-- Armor --}}
      <section class="armor-section">
        <h3>{{localize "DARKEST.Armor.Name"}}</h3>
        <div class="armor-grid">
          <div class="armor-row">
            <label>{{localize "DARKEST.Armor.Physical"}}</label>
            <input type="number" name="system.armor.physical" value="{{system.armor.physical}}" data-dtype="Number"
              min="0" max="3" />
            <span class="defense-rating">
              ({{localize "DARKEST.Rating"}}: {{effectiveRatings.defense.physical}})
            </span>
          </div>
        </div>
      </section>

      {{!-- Wounds --}}
      <section class="wounds-section">
        <div class="section-header">
          <h3>{{localize "DARKEST.Wound.Plural"}}</h3>
          <span class="wound-count">
            {{activeWounds.length}} active
            {{#if healedWounds.length}}({{healedWounds.length}} healed){{/if}}
          </span>
          <button type="button" class="item-create" data-type="wound" title="{{localize 'DARKEST.Wound.New'}}">
            <i class="fas fa-plus"></i>
          </button>
        </div>

        {{#if highestWoundRating}}
        <div class="highest-wound-indicator">
          <i class="fas fa-exclamation-triangle"></i>
          {{localize "DARKEST.Wound.HighestRating"}}: {{highestWoundRating}}
        </div>
        <div class="wound-actions flexrow">
          {{#if canResistUnconscious}}
          <button type="button" class="resist-unconscious" title="Roll to resist falling unconscious or catatonic">
            <i class="fas fa-fist-raised"></i>
            {{#if (eq system.highestWoundType 'mental')}}Resist Catatonia{{else}}Resist Unconsciousness{{/if}}
          </button>
          {{/if}}
          {{#if canDeathCheck}}
          <button type="button" class="death-check {{#if deathCheckUrgent}}urgent{{/if}}"
            title="Roll vs Highest Wound Rating minus Dooms">
            {{#if (eq system.highestWoundType 'mental')}}<i class="fas fa-brain"></i> Catatonia Check{{else}}<i class="fas fa-heartbeat"></i> Death Check{{/if}}
          </button>
          {{/if}}
          <button type="button" class="rest-wounds" title="Roll 2d6 + Rating vs each wound's Rating to recover">
            <i class="fas fa-campfire"></i> Rest
          </button>
          <button type="button" class="heal-wound-btn" title="Remove a wound (choose lowest, highest, or specific)">
            <i class="fas fa-medkit"></i> Heal Wound
          </button>
        </div>
        {{/if}}

        <ol class="item-list wounds-list">
          {{#each activeWounds}}
          <li class="item wound {{#if system.healed}}healed{{/if}} {{#if restLocked}}rest-locked{{/if}}" data-item-id="{{_id}}">
            <div class="wound-rating">
              <span class="rating-badge {{system.type}}">{{system.rating}}</span>
            </div>
            <div class="wound-info">
              <span class="wound-name">{{name}}</span>
              <span class="wound-type">{{system.type}}</span>
              {{#if restLocked}}<span class="wound-locked-badge" title="Cannot rest — failed within 24h"><i class="fas fa-lock"></i></span>{{/if}}
            </div>
            <div class="item-controls">
              {{#if restLocked}}{{#if @root.isGM}}
              <a class="wound-unlock" title="GM: Unlock rest (remove 24h lockout)"><i class="fas fa-unlock"></i></a>
              {{/if}}{{/if}}
              <a class="wound-heal" title="{{#if system.healed}}Unmark Healed{{else}}Mark Healed{{/if}}">
                <i class="fas {{#if system.healed}}fa-heart{{else}}fa-heart-broken{{/if}}"></i>
              </a>
              <a class="item-edit" title="Edit"><i class="fas fa-edit"></i></a>
              <a class="item-delete" title="Delete"><i class="fas fa-trash"></i></a>
            </div>
          </li>
          {{/each}}

          {{#if healedWounds.length}}
          <li class="item-header healed-header">Healed Wounds</li>
          {{#each healedWounds}}
          <li class="item wound healed" data-item-id="{{_id}}">
            <div class="wound-rating">
              <span class="rating-badge {{system.type}} healed">{{system.rating}}</span>
            </div>
            <div class="wound-info">
              <span class="wound-name">{{name}}</span>
              <span class="wound-type">{{system.type}}</span>
            </div>
            <div class="item-controls">
              <a class="wound-heal" title="Unmark Healed">
                <i class="fas fa-heart"></i>
              </a>
              <a class="item-edit" title="Edit"><i class="fas fa-edit"></i></a>
              <a class="item-delete" title="Delete"><i class="fas fa-trash"></i></a>
            </div>
          </li>
          {{/each}}
          {{/if}}
        </ol>

        {{#unless wounds.length}}
        <p class="empty-list">No wounds - stay safe in the woods!</p>
        {{/unless}}
      </section>

      {{!-- Dooms --}}
      <section class="dooms-section">
        <div class="section-header">
          <h3>{{localize "DARKEST.Doom.Plural"}}</h3>
          <span class="doom-count">{{unresolvedDooms.length}} active</span>
          <button type="button" class="item-create" data-type="doom" title="{{localize 'DARKEST.Doom.New'}}">
            <i class="fas fa-plus"></i>
          </button>
        </div>

        {{!-- Doom Action Buttons --}}
        {{#if unresolvedDooms.length}}
        <div class="doom-actions flexrow">
          <button type="button" class="doom-spend" title="Spend a Doom to lower your count (GM gets permission to do something terrible)">
            <i class="fas fa-skull"></i> Spend Doom
          </button>
        </div>
        {{/if}}

        <ol class="item-list dooms-list">
          {{#each dooms}}
          <li class="item doom {{#if system.resolved}}resolved{{/if}}" data-item-id="{{_id}}">
            <div class="doom-icon">
              <i class="fas fa-skull"></i>
            </div>
            <div class="doom-info">
              <span class="doom-name">{{name}}</span>
              {{#if system.source}}
              <span class="doom-source">Source: {{system.source}}</span>
              {{/if}}
            </div>
            <div class="item-controls">
              <a class="doom-resolve" title="{{#if system.resolved}}Unresolve{{else}}Resolve{{/if}}">
                <i class="fas {{#if system.resolved}}fa-check-circle{{else}}fa-circle{{/if}}"></i>
              </a>
              <a class="item-edit" title="Edit"><i class="fas fa-edit"></i></a>
              <a class="item-delete" title="Delete"><i class="fas fa-trash"></i></a>
            </div>
          </li>
          {{/each}}
        </ol>

        {{#unless dooms.length}}
        <p class="empty-list">No dooms... yet.</p>
        {{/unless}}
      </section>

    </div>

    {{!-- Abilities Tab --}}
    <div class="tab abilities" data-group="primary" data-tab="abilities">

      {{!-- Skills/Talents (Rating Modifiers) --}}
      <section class="modifications-section">
        <div class="modifications-header">
          <span class="modifications-title">Skills / Talents</span>
          <button type="button" class="add-modification" title="Add skill or talent">
            <i class="fas fa-plus"></i>
          </button>
        </div>
        <div class="modifications-grid">
          {{#each customModifications}}
          <div class="modification-row custom-mod" data-index="{{@index}}">
            <input type="text" class="mod-name" name="system.customModifications.{{@index}}.name"
              value="{{name}}" placeholder="Skill or talent name" />
            <input type="number" class="mod-value" name="system.customModifications.{{@index}}.value"
              value="{{value}}" data-dtype="Number" title="Modifier to base rating" />
            <span class="effective" title="Effective rating">({{effectiveValue}})</span>
            <button type="button" class="remove-modification" data-index="{{@index}}" title="Remove">
              <i class="fas fa-times"></i>
            </button>
          </div>
          {{/each}}
          {{#unless customModifications.length}}
          <p class="no-modifications">No skills or talents yet — click + to add one.</p>
          {{/unless}}
        </div>
      </section>

    </div>

    {{!-- Equipment Tab --}}
    <div class="tab equipment" data-group="primary" data-tab="equipment">
      <section class="equipment-section">
        <div class="section-header">
          <h3>{{localize "DARKEST.Equipment.Plural"}}</h3>
          <button type="button" class="item-create" data-type="equipment"
            title="{{localize 'DARKEST.Equipment.New'}}">
            <i class="fas fa-plus"></i>
          </button>
        </div>

        <ol class="item-list equipment-list">
          {{#each equipment}}
          <li class="item equipment-item" data-item-id="{{_id}}">
            <img src="{{img}}" class="item-img" />
            <div class="equipment-info">
              <span class="equipment-name">{{name}}</span>
              {{#if system.armorType}}
              {{#unless (eq system.armorType "none")}}
              <span class="armor-type">
                <i class="fas fa-shield-alt"></i>
                {{lookup @root.config.armorTypes system.armorType}}
              </span>
              {{/unless}}
              {{/if}}
            </div>
            <div class="item-controls">
              <a class="item-edit" title="Edit"><i class="fas fa-edit"></i></a>
              <a class="item-delete" title="Delete"><i class="fas fa-trash"></i></a>
            </div>
          </li>
          {{/each}}
        </ol>

        {{#unless equipment.length}}
        <p class="empty-list">No equipment carried.</p>
        {{/unless}}
      </section>
    </div>

    {{!-- Biography Tab --}}
    <div class="tab biography" data-group="primary" data-tab="biography">
      <section class="biography-section">
        <h3>{{localize "DARKEST.Actor.Biography"}}</h3>
        <div class="editor-container">
          {{editor enrichedBiography target="system.biography" button=true editable=true}}
        </div>
      </section>

      <section class="notes-section">
        <h3>{{localize "DARKEST.Actor.Notes"}}</h3>
        <div class="editor-container">
          {{editor enrichedNotes target="system.notes" button=true editable=true}}
        </div>
      </section>
    </div>

  </section>

</form>
