<form class="darkest-dialog take-damage-dialog">
  <p class="dialog-hint"><i class="fas fa-heart-broken"></i><span>You are <strong>taking damage</strong> — roll to see how badly you're hurt.</span></p>

  <div class="form-group">
    <label>Enemy Attack {{localize "DARKEST.Rating"}}</label>
    <select name="enemyAttack" class="enemy-attack-select">
      {{#each taskDifficulty}}
      <option value="{{rating}}" {{#if (eq rating 4)}}selected{{/if}}>
        {{label}} ({{rating}})
      </option>
      {{/each}}
    </select>
    <small class="hint">The attacker's Rating</small>
  </div>

  <div class="form-group">
    <label>Wound Type</label>
    <select name="woundType" class="wound-type-select">
      <option value="physical">{{localize "DARKEST.Wound.Physical"}}</option>
      <option value="mental">{{localize "DARKEST.Wound.Mental"}}</option>
    </select>
    <small class="hint">Armor only applies to physical wounds</small>
  </div>

  {{#if ratingModifiers.length}}
  <div class="form-group">
    <label>Skill / Modifier</label>
    <select name="ratingModifier" class="rating-modifier-select">
      <option value="" data-modifier="0">Base Rating ({{characterRating}})</option>
      {{#each ratingModifiers}}
      <option value="{{name}}" data-modifier="{{value}}">{{name}} ({{effectiveValue}})</option>
      {{/each}}
    </select>
  </div>
  {{/if}}

  <div class="form-group calculated-defense">
    <label>Your Defense</label>
    {{!-- Breakdown row: Rating + Armor + Skill = Base --}}
    <div class="defense-breakdown">
      <div class="defense-breakdown-cell">
        <span class="breakdown-cell-label">Rating</span>
        <span class="breakdown-cell-value">{{ownRating}}</span>
      </div>
      <span class="breakdown-op">+</span>
      <div class="defense-breakdown-cell">
        <span class="breakdown-cell-label">Armor</span>
        <span class="breakdown-cell-value armor-value">{{physicalArmor}}</span>
      </div>
      <span class="breakdown-op skill-mod-display" style="display:none">+</span>
      <div class="defense-breakdown-cell skill-mod-display" style="display:none">
        <span class="breakdown-cell-label">Skill</span>
        <span class="breakdown-cell-value skill-mod-value">0</span>
      </div>
      <span class="breakdown-op">=</span>
      <div class="defense-breakdown-cell defense-base-cell">
        <span class="breakdown-cell-label">Base</span>
        <span class="breakdown-cell-value defense-total">{{physicalDefense}}</span>
      </div>
    </div>
    {{!-- Situational modifier row --}}
    <div class="defense-adj-row">
      <label class="defense-adj-label">Situational modifier</label>
      <div class="counter-controls rating-adj-controls">
        <button type="button" class="counter-btn decrement" data-field="defenseAdj"><i class="fas fa-minus"></i></button>
        <input type="number" name="defenseAdj" value="0" min="-5" max="10" readonly />
        <button type="button" class="counter-btn increment" data-field="defenseAdj"><i class="fas fa-plus"></i></button>
      </div>
    </div>
    <div class="defense-total-row">
      <span class="defense-total-label">Total defense:</span>
      <strong class="effective-defense-display">{{physicalDefense}}</strong>
    </div>
  </div>

  <div class="form-group boon-bane-group">
    <label>{{localize "DARKEST.Dialog.NumBoons"}}</label>
    <div class="counter-controls">
      <button type="button" class="counter-btn decrement" data-field="boons"><i class="fas fa-minus"></i></button>
      <input type="number" name="boons" value="0" min="0" max="5" readonly />
      <button type="button" class="counter-btn increment" data-field="boons"><i class="fas fa-plus"></i></button>
    </div>
  </div>

  <div class="form-group boon-bane-group">
    <label>{{localize "DARKEST.Dialog.NumBanes"}}</label>
    <div class="counter-controls">
      <button type="button" class="counter-btn decrement" data-field="banes" data-min="{{woundBanes}}"><i class="fas fa-minus"></i></button>
      <input type="number" name="banes" value="{{banes}}" min="{{woundBanes}}" max="5" readonly data-wound-banes="{{woundBanes}}" />
      <button type="button" class="counter-btn increment" data-field="banes"><i class="fas fa-plus"></i></button>
    </div>
    {{#if woundBanes}}
    <small class="hint locked-banes"><i class="fas fa-lock"></i> {{woundBanes}} from wounds (cannot reduce)</small>
    {{/if}}
  </div>

  <div class="boon-bane-descriptor" style="display:none;">
    <small class="boon-bane-text"></small>
  </div>

  {{#if equipment.length}}
  <div class="dialog-equipment-ref">
    <div class="dialog-equip-header collapsed"><i class="fas fa-chevron-down"></i> Equipment</div>
    <div class="dialog-equip-list collapsed">
      {{#each equipment}}
      <div class="dialog-equip-item">
        <span class="equip-name">{{name}}</span>
        {{#if system.combatNote}}<span class="equip-note">{{system.combatNote}}</span>{{/if}}
      </div>
      {{/each}}
    </div>
  </div>
  {{/if}}
</form>
